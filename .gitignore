# This directory is loaded as an unpacked Chrome extension AND holds the Python
# test tooling (machine-test.py, testserver.py, gen-testpage.py). Chrome refuses
# to load an extension containing any "_"-prefixed file or directory, so Python
# bytecode caches must never sit here. Keep them ignored.
# NOTE: syntax-check with `python3 -c "import ast; ast.parse(open('f.py').read())"`,
# NOT `python3 -m py_compile` — py_compile writes __pycache__ even under
# PYTHONDONTWRITEBYTECODE=1 (that is its job), which breaks the unpacked load.
__pycache__/
*.pyc

# Store build artifacts (regenerated by build-store-zip.sh). The screenshots ARE
# committed (reviewable deliverables); the staging dir and the zip are throwaway.
store/pkg/
store/*.zip
